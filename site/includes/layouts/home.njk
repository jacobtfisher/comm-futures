---
layout: base
---

<main id="main" class="main inner box-flex pt-800 pb-1100" tabindex="-1">

    <header class="page-header">

        <img src="{{ '/images/meta/futures_logo.png' | url }}" class="hero-image">
        {% if sub_heading %}

            <p class="sub-heading">{{ sub_heading }}</p>

        {% endif %}

    </header>

    <div class="content flow">
        {% if intro %}
        <p>{{ intro | safe }}</p>
        {% endif %}
        {% if key_details %}
        <div class="home-info-cards" aria-label="Key conference details">
            {% for item in key_details %}
            <div class="home-info-card">
                <div class="card-body">
                    <span class="card-label">{{ item.label }}</span>
                    <span class="card-value">{{ item.value | safe }}</span>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}
        {{ content | safe }}
    </div>

</main>
